{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Auto-merge container digests for trusted containers",
      "matchDatasources": ["docker"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["digest"],
      "ignoreTests": true,
      "matchPackagePrefixes": [
        "ghcr.io/bjw-s",
        "ghcr.io/onedr0p",
        "ghcr.io/home-operations"
      ]
    },
    {
      "description": "Auto-merge Mise tools",
      "matchManagers": ["mise"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["minor", "patch"],
      "ignoreTests": true,
      "matchPackageNames": [
        "!aqua:siderolabs/talos",
        "!aqua:kubernetes/kubectl"
      ]
    },
    {
      "description": "Auto-merge GitHub Actions",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "minimumReleaseAge": "3 days",
      "ignoreTests": true
    },
    {
      "description": "Auto-merge trusted container and helm minor/patch updates",
      "matchDatasources": ["docker", "helm"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "ghcr.io/seerr-team/seerr",
        "ghcr.io/autobrr/autobrr",
        "ghcr.io/autobrr/qui",
        "ghcr.io/hargata/lubelogger",
        "ghcr.io/home-operations/bazarr",
        "ghcr.io/home-operations/prowlarr",
        "ghcr.io/home-operations/radarr",
        "ghcr.io/home-operations/sonarr",
        "ghcr.io/home-operations/sabnzbd",
        "ghcr.io/home-operations/tautulli",
        "ghcr.io/home-operations/tqm",
        "ghcr.io/twin/gatus"
      ]
    }
  ]
}
